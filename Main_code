   "source": "from sklearn.metrics.pairwise import cosine_similarity\nfrom sklearn.feature_extraction.text import TfidfVectorizer\nimport warnings\nwarnings.filterwarnings(\"ignore\")\n\n\n# Robustness Check 1: Vocabulary Overlap\n# Compares n-gram vocabularies of synthetic vs real training data.\n# High overlap means synthetic text stays within the linguistic distribution of real reports.\n\nprint(\"\\n\" + \"=\" * 65)\nprint(\"  ROBUSTNESS CHECK 1: Vocabulary Overlap\")\nprint(\"=\" * 65)\n\nif synthetic_df is None or len(synthetic_df) == 0:\n    print(\"  SKIPPED — no synthetic data loaded.\")\nelse:\n    vec_real = TfidfVectorizer(ngram_range=(1, 2), max_features=10_000, sublinear_tf=True)\n    vec_syn  = TfidfVectorizer(ngram_range=(1, 2), max_features=10_000, sublinear_tf=True)\n\n    vec_real.fit(train_df[\"text\"])\n    vec_syn.fit(synthetic_df[\"text\"])\n\n    real_vocab    = set(vec_real.vocabulary_.keys())\n    syn_vocab     = set(vec_syn.vocabulary_.keys())\n    overlap       = real_vocab & syn_vocab\n    exclusive_syn = syn_vocab - real_vocab\n    overlap_rate  = len(overlap) / max(len(syn_vocab), 1) * 100\n\n    print(f\"\\n  Real training vocabulary : {len(real_vocab):>6} unique n-grams\")\n    print(f\"  Synthetic vocabulary     : {len(syn_vocab):>6} unique n-grams\")\n    print(f\"  Shared                   : {len(overlap):>6} n-grams\")\n    print(f\"  Exclusive to synthetic   : {len(exclusive_syn):>6} n-grams\")\n    print(f\"  Overlap rate             : {overlap_rate:.1f}%\")\n\n    if overlap_rate >= 80:\n        print(\"  \\u2192 Low domain shift risk.\")\n    elif overlap_rate >= 60:\n        print(\"  \\u2192 Some novel vocabulary present — monitor carefully.\")\n    else:\n        print(\"  \\u2192 Substantial vocabulary mismatch — consider stricter filtering.\")\n\n    syn_matrix     = vec_syn.transform(synthetic_df[\"text\"])\n    term_scores    = np.asarray(syn_matrix.mean(axis=0)).flatten()\n    syn_terms      = vec_syn.get_feature_names_out()\n    term_score_map = dict(zip(syn_terms, term_scores))\n\n    alien_terms = {t: s for t, s in term_score_map.items() if t in exclusive_syn and s > 0}\n    top_alien   = sorted(alien_terms.items(), key=lambda x: x[1], reverse=True)[:20]\n\n    if top_alien:\n        print(f\"\\n  Top 20 terms present only in synthetic data (by TF-IDF score):\")\n        print(f\"  {'Term':<35} {'TF-IDF score':>12}\")\n        print(f\"  {'-'*48}\")\n        for term, score in top_alien:\n            print(f\"  {term:<35} {score:>12.5f}\")\n\n    print(f\"\\n  Per-label overlap:\")\n    for label in [\"substantive\", \"symbolic\"]:\n        subset   = synthetic_df[synthetic_df[\"binary_label\"] == label]\n        vec_l    = TfidfVectorizer(ngram_range=(1, 2), max_features=5_000, sublinear_tf=True)\n        vec_l.fit(subset[\"text\"])\n        l_vocab   = set(vec_l.vocabulary_.keys())\n        l_overlap = l_vocab & real_vocab\n        l_rate    = len(l_overlap) / max(len(l_vocab), 1) * 100\n        print(f\"    {label:<15}: {len(l_vocab):>5} syn terms | \"\n              f\"{len(l_overlap):>5} overlap | {l_rate:.1f}%\")\n\n\n# Robustness Check 2: Cosine Similarity Filter\n# Removes synthetic sentences that are too dissimilar to any real training sentence.\n# Similarity is measured in the real-data TF-IDF feature space.\n# Threshold guide: >0.10 loose, >0.15 moderate (default), >0.25 strict.\n\nprint(\"\\n\" + \"=\" * 65)\nprint(\"  ROBUSTNESS CHECK 2: Cosine Similarity Filter\")\nprint(\"=\" * 65)\n\nSIMILARITY_THRESHOLD = 0.15\n\nif synthetic_df is None or len(synthetic_df) == 0:\n    print(\"  SKIPPED — no synthetic data loaded.\")\nelse:\n    print(f\"\\n  Threshold: cosine similarity > {SIMILARITY_THRESHOLD}\")\n\n    vec_filter  = TfidfVectorizer(ngram_range=(1, 2), max_features=10_000, sublinear_tf=True)\n    vec_filter.fit(train_df[\"text\"])\n\n    real_matrix = vec_filter.transform(train_df[\"text\"])\n    syn_matrix  = vec_filter.transform(synthetic_df[\"text\"])\n\n    batch_size = 100\n    max_sim    = []\n    for i in range(0, len(synthetic_df), batch_size):\n        batch      = syn_matrix[i:i + batch_size]\n        sim_matrix = cosine_similarity(batch, real_matrix)\n        max_sim.extend(sim_matrix.max(axis=1).tolist())\n\n    synthetic_df = synthetic_df.copy()\n    synthetic_df[\"max_cosine_sim\"] = max_sim\n\n    syn_filtered = synthetic_df[synthetic_df[\"max_cosine_sim\"] >  SIMILARITY_THRESHOLD]\n    syn_removed  = synthetic_df[synthetic_df[\"max_cosine_sim\"] <= SIMILARITY_THRESHOLD]\n    kept_rate    = len(syn_filtered) / max(len(synthetic_df), 1) * 100\n\n    print(f\"\\n  Before filter : {len(synthetic_df)}\")\n    print(f\"  Removed       : {len(syn_removed)}  ({100 - kept_rate:.1f}%)\")\n    print(f\"  Kept          : {len(syn_filtered)}  ({kept_rate:.1f}%)\")\n    print(f\"\\n  Similarity distribution:\")\n    print(f\"    Min    : {min(max_sim):.4f}\")\n    print(f\"    Median : {sorted(max_sim)[len(max_sim) // 2]:.4f}\")\n    print(f\"    Mean   : {sum(max_sim) / len(max_sim):.4f}\")\n    print(f\"    Max    : {max(max_sim):.4f}\")\n\n    if len(syn_removed) > 0:\n        print(f\"\\n  Most out-of-distribution removed sentences:\")\n        for _, row in syn_removed.nsmallest(5, \"max_cosine_sim\").iterrows():\n            print(f\"\\n    [{row['binary_label']}] sim={row['max_cosine_sim']:.4f}\")\n            print(f\"    \\\"{row['text'][:120]}\\\"\")\n\n    if len(syn_filtered) > 0:\n        print(f\"\\n  Most in-distribution kept sentences:\")\n        for _, row in syn_filtered.nlargest(3, \"max_cosine_sim\").iterrows():\n            print(f\"\\n    [{row['binary_label']}] sim={row['max_cosine_sim']:.4f}\")\n            print(f\"    \\\"{row['text'][:120]}\\\"\")\n\n    if len(syn_filtered) < max(SCARCITY_LEVELS):\n        print(f\"\\n  WARNING: Only {len(syn_filtered)} filtered examples remain \"\n              f\"(fewer than largest scarcity level {max(SCARCITY_LEVELS)}).\")\n\n    print(f\"\\n  Re-running experiments with filtered synthetic data (threshold={SIMILARITY_THRESHOLD})...\")\n    results_filtered = run_experiments(\n        train_df        = train_df,\n        test_df         = test_df,\n        synthetic_df    = syn_filtered[[\"text\", \"binary_label\"]],\n        scarcity_levels = SCARCITY_LEVELS,\n        seed            = SEED,\n    )\n\n    aug_orig     = {r[\"scarcity_level\"]: r for r in results          if r[\"condition\"] == \"augmented\"}\n    aug_filtered = {r[\"scarcity_level\"]: r for r in results_filtered if r[\"condition\"] == \"augmented\"}\n    real_only    = {r[\"scarcity_level\"]: r for r in results          if r[\"condition\"] == \"real_only\"}\n\n    print(f\"\\n  Comparison: real-only vs augmented (original) vs augmented (filtered)\")\n    print(f\"  {'n':>5} {'real_only':>10} {'aug_orig':>10} {'aug_filt':>10} \"\n          f\"{'\\u0394F1_orig':>10} {'\\u0394F1_filt':>10}\")\n    print(f\"  {'-'*58}\")\n    for n in SCARCITY_LEVELS:\n        r_f1 = real_only.get(n,    {}).get(\"f1_macro\", float(\"nan\"))\n        o_f1 = aug_orig.get(n,     {}).get(\"f1_macro\", float(\"nan\"))\n        f_f1 = aug_filtered.get(n, {}).get(\"f1_macro\", float(\"nan\"))\n        d_o  = o_f1 - r_f1 if o_f1 == o_f1 else float(\"nan\")\n        d_f  = f_f1 - r_f1 if f_f1 == f_f1 else float(\"nan\")\n        print(f\"  {n:>5} {r_f1:>10.4f} {o_f1:>10.4f} {f_f1:>10.4f} \"\n              f\"{d_o:>+10.4f} {d_f:>+10.4f}\")\n\n    FILTERED_RESULTS_PATH = RESULTS_PATH.replace(\".csv\", \"_filtered_synthetic.csv\")\n    exclude = {\"report\", \"confusion_matrix\"}\n    pd.DataFrame([{k: v for k, v in r.items() if k not in exclude}\n                  for r in results_filtered]).to_csv(FILTERED_RESULTS_PATH, index=False)\n    print(f\"\\n  Filtered results saved \\u2192 '{FILTERED_RESULTS_PATH}'\")\n\n\n# Robustness Check 3: Temperature Control\n# Synthetic data was generated at temperature=0.3 to reduce hallucinated vocabulary\n# and keep outputs within the linguistic distribution of real ESG reporting language.\n# Set REGENERATE_LOW_TEMP = True to regenerate and compare against the original.\n\nprint(\"\\n\" + \"=\" * 65)\nprint(\"  ROBUSTNESS CHECK 3: Temperature Control\")\nprint(\"=\" * 65)\n\nREGENERATE_LOW_TEMP = False\nLOW_TEMP = 0.3\n\nprint(f\"\\n  Generation temperature used: {LOW_TEMP}\")\nprint(f\"  Lower temperature reduces the risk of out-of-distribution vocabulary.\")\n\nif REGENERATE_LOW_TEMP:\n    if not ANTHROPIC_API_KEY:\n        print(\"\\n  SKIPPED — no API key found.\")\n    else:\n        import anthropic as _anthropic\n\n        LOW_TEMP_PATH = SYNTHETIC_PATH.replace(\".json\", f\"_temp{LOW_TEMP}.json\")\n\n        def generate_low_temp(train_df, n_per_label, api_key, temperature, seed=SEED):\n            client = _anthropic.Anthropic(api_key=api_key)\n            existing_texts = set(train_df[\"text\"].tolist())\n            all_synthetic  = []\n\n            for label, prompt_template in [\n                (\"substantive\", SUBSTANTIVE_PROMPT),\n                (\"symbolic\",    SYMBOLIC_PROMPT),\n            ]:\n                print(f\"  Generating {n_per_label} '{label}' examples (temp={temperature})...\")\n                pool      = train_df[train_df[\"binary_label\"] == label][\"text\"].tolist()\n                rng       = random.Random(seed)\n                examples  = rng.sample(pool, min(4, len(pool)))\n                generated = []\n                attempts  = 0\n\n                while len(generated) < n_per_label and attempts < n_per_label * 3:\n                    ex1    = examples[attempts % len(examples)]\n                    ex2    = examples[(attempts + 1) % len(examples)]\n                    prompt = prompt_template.format(ex1=ex1, ex2=ex2)\n                    try:\n                        resp = client.messages.create(\n                            model=\"claude-sonnet-4-20250514\",\n                            max_tokens=200,\n                            temperature=temperature,\n                            messages=[{\"role\": \"user\", \"content\": prompt}],\n                        )\n                        text = resp.content[0].text.strip()\n                        if 8 <= len(text.split()) <= 80:\n                            generated.append(text)\n                    except Exception as e:\n                        print(f\"    API error: {e}\")\n                        time.sleep(2)\n                    attempts += 1\n                    if attempts % 20 == 0:\n                        time.sleep(1)\n\n                clean = deduplicate(generated, existing_texts)[:n_per_label]\n                for text in clean:\n                    all_synthetic.append({\n                        \"text\": text, \"binary_label\": label,\n                        \"synthetic\": True, \"temperature\": temperature,\n                    })\n\n            df_out = pd.DataFrame(all_synthetic)\n            df_out.to_json(LOW_TEMP_PATH, orient=\"records\", indent=2)\n            print(f\"\\n  Saved {len(df_out)} low-temp examples \\u2192 '{LOW_TEMP_PATH}'\")\n            return df_out\n\n        syn_low_temp = generate_low_temp(\n            train_df, max(SCARCITY_LEVELS), ANTHROPIC_API_KEY, LOW_TEMP\n        )\n\n        print(f\"\\n  Vocabulary overlap comparison:\")\n        vec_base        = TfidfVectorizer(ngram_range=(1, 2), max_features=10_000, sublinear_tf=True)\n        vec_base.fit(train_df[\"text\"])\n        real_vocab_base = set(vec_base.vocabulary_.keys())\n\n        for label, df_s in [(\"Original temp\", synthetic_df), (\"Low temp\", syn_low_temp)]:\n            if df_s is None or len(df_s) == 0:\n                continue\n            v    = TfidfVectorizer(ngram_range=(1, 2), max_features=10_000, sublinear_tf=True)\n            v.fit(df_s[\"text\"])\n            voc  = set(v.vocabulary_.keys())\n            olap = voc & real_vocab_base\n            rate = len(olap) / max(len(voc), 1) * 100\n            print(f\"  {label:<20}: {len(voc):>5} terms | {len(olap):>5} overlap | {rate:.1f}%\")\n\n        print(f\"\\n  Running experiments with low-temp synthetic data...\")\n        results_low_temp = run_experiments(\n            train_df        = train_df,\n            test_df         = test_df,\n            synthetic_df    = syn_low_temp[[\"text\", \"binary_label\"]],\n            scarcity_levels = SCARCITY_LEVELS,\n            seed            = SEED,\n        )\n\n        aug_low  = {r[\"scarcity_level\"]: r for r in results_low_temp if r[\"condition\"] == \"augmented\"}\n        real_b   = {r[\"scarcity_level\"]: r for r in results           if r[\"condition\"] == \"real_only\"}\n        aug_orig = {r[\"scarcity_level\"]: r for r in results           if r[\"condition\"] == \"augmented\"}\n\n        print(f\"\\n  Temperature comparison: augmented F1 macro\")\n        print(f\"  {'n':>5} {'real_only':>10} {'orig_temp':>10} {'low_temp':>10}\")\n        print(f\"  {'-'*40}\")\n        for n in SCARCITY_LEVELS:\n            r_f1 = real_b.get(n,   {}).get(\"f1_macro\", float(\"nan\"))\n            o_f1 = aug_orig.get(n, {}).get(\"f1_macro\", float(\"nan\"))\n            l_f1 = aug_low.get(n,  {}).get(\"f1_macro\", float(\"nan\"))\n            print(f\"  {n:>5} {r_f1:>10.4f} {o_f1:>10.4f} {l_f1:>10.4f}\")\n\n        LOW_TEMP_RESULTS_PATH = RESULTS_PATH.replace(\".csv\", f\"_lowtemp{LOW_TEMP}.csv\")\n        exclude = {\"report\", \"confusion_matrix\"}\n        pd.DataFrame([{k: v for k, v in r.items() if k not in exclude}\n                      for r in results_low_temp]).to_csv(LOW_TEMP_RESULTS_PATH, index=False)\n        print(f\"\\n  Low-temp results saved \\u2192 '{LOW_TEMP_RESULTS_PATH}'\")\nelse:\n    print(f\"  Set REGENERATE_LOW_TEMP = True to regenerate at temperature={LOW_TEMP}.\")\n"
