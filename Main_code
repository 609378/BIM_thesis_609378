   "source": "# File paths\nTRAIN_PATH     = \"/kaggle/input/datasets/annieyang14/fold-1-seen-train-json/fold_1_seen_train (3).json\"\nTEST_PATH      = \"/kaggle/input/datasets/annieyang14/fold-1-seen-test-json/fold_1_seen_test (1).json\"\nSYNTHETIC_PATH = \"/kaggle/input/datasets/annieyang14/synthetic-data-generated/synthetic_data_master (1).json\"\nRESULTS_PATH   = \"/kaggle/working/results.csv\"\n\n# Four scarcity levels (50, 100, 200, 500 aspect instances)\nSCARCITY_LEVELS = [50, 100, 200, 500]\n\nSEED = 42\n\n# 1:1 ratio of synthetic to real training instances\nSYNTHETIC_RATIO = 1.0\n\n# Set to True on first run to generate synthetic data; False afterward to skip re-generation\nGENERATE_SYNTHETIC = False\n\ntry:\n    from kaggle_secrets import UserSecretsClient\n    user_secrets = UserSecretsClient()\n    ANTHROPIC_API_KEY = user_secrets.get_secret(\"ANTHROPIC_API_KEY\")\nexcept ImportError:\n    print(\"Warning: Could not connect to Kaggle Secrets.\")\n    ANTHROPIC_API_KEY = \"\"\n\n# Implemented and Planning map to substantive; Indeterminate and no action map to symbolic\nLABEL_MAP = {\n    \"implemented\":   \"substantive\",\n    \"planning\":      \"substantive\",\n    \"indeterminate\": \"symbolic\",\n    \"no action\":     \"symbolic\",\n}\n\nrandom.seed(SEED)\nnp.random.seed(SEED)\n"
