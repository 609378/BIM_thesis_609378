   "source": "def build_model():\n    \"\"\"\n    Returns a fresh TF-IDF vectorizer and Logistic Regression classifier.\n    Called once per experimental condition.\n\n    TF-IDF: unigrams and bigrams, top 10,000 n-grams, sublinear TF scaling.\n    Logistic Regression: balanced class weights, C=1.0, lbfgs solver.\n    \"\"\"\n    vectorizer = TfidfVectorizer(\n        ngram_range=(1, 2),\n        max_features=10_000,\n        sublinear_tf=True,\n    )\n    clf = LogisticRegression(\n        max_iter=1000,\n        solver=\"lbfgs\",\n        class_weight=\"balanced\",\n        random_state=SEED,\n        C=1.0,\n    )\n    return vectorizer, clf\n\n\ndef train_and_evaluate(train_df, test_df):\n    \"\"\"\n    Trains the model on train_df and evaluates on test_df.\n    Primary metric is macro F1; precision, recall, and accuracy are also returned.\n    \"\"\"\n    vectorizer, clf = build_model()\n\n    X_train = vectorizer.fit_transform(train_df[\"text\"])\n    y_train = train_df[\"binary_label\"].values\n\n    X_test = vectorizer.transform(test_df[\"text\"])\n    y_test = test_df[\"binary_label\"].values\n\n    clf.fit(X_train, y_train)\n    y_pred = clf.predict(X_test)\n\n    return {\n        \"f1_macro\":        f1_score(y_test, y_pred, average=\"macro\"),\n        \"f1_substantive\":  f1_score(y_test, y_pred, pos_label=\"substantive\", average=\"binary\"),\n        \"f1_symbolic\":     f1_score(y_test, y_pred, pos_label=\"symbolic\",    average=\"binary\"),\n        \"precision_macro\": precision_score(y_test, y_pred, average=\"macro\",  zero_division=0),\n        \"recall_macro\":    recall_score(y_test, y_pred,    average=\"macro\",  zero_division=0),\n        \"accuracy\":        accuracy_score(y_test, y_pred),\n        \"n_train\":               len(train_df),\n        \"train_substantive\":     int((y_train == \"substantive\").sum()),\n        \"train_symbolic\":        int((y_train == \"symbolic\").sum()),\n        \"report\":                classification_report(y_test, y_pred, zero_division=0),\n        \"confusion_matrix\":      confusion_matrix(\n                                     y_test, y_pred,\n                                     labels=[\"substantive\", \"symbolic\"]\n                                 ).tolist(),\n    }\n"
