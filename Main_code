   "source": "def run_experiments(train_df, test_df, synthetic_df, scarcity_levels, seed=SEED):\n    \"\"\"\n    Runs all experimental conditions and returns a list of result dicts.\n\n    For each scarcity level:\n      Condition A (real_only):  train on n real instances\n      Condition B (augmented):  train on n real + n synthetic instances (1:1 ratio)\n\n    Both conditions are evaluated on the same fixed test set.\n    \"\"\"\n    results = []\n\n    for n in scarcity_levels:\n        print(f\"\\n{'='*60}\")\n        print(f\"  SCARCITY LEVEL: {n} real aspect instances\")\n        print(f\"{'='*60}\")\n\n        real_sample = stratified_sample(train_df, n, seed=seed)\n        actual_n    = len(real_sample)\n        print(f\"  Sampled: {actual_n} | {dict(real_sample['binary_label'].value_counts())}\")\n\n        metrics_a = train_and_evaluate(real_sample, test_df)\n        results.append({\n            \"scarcity_level\":           n,\n            \"condition\":                \"real_only\",\n            \"n_real\":                   actual_n,\n            \"n_synthetic\":              0,\n            \"n_total_train\":            actual_n,\n            \"f1_macro\":                 metrics_a[\"f1_macro\"],\n            \"f1_substantive\":           metrics_a[\"f1_substantive\"],\n            \"f1_symbolic\":              metrics_a[\"f1_symbolic\"],\n            \"precision_macro\":          metrics_a[\"precision_macro\"],\n            \"recall_macro\":             metrics_a[\"recall_macro\"],\n            \"accuracy\":                 metrics_a[\"accuracy\"],\n            \"f1_improvement_over_real\": 0.0,\n            \"report\":                   metrics_a[\"report\"],\n            \"confusion_matrix\":         str(metrics_a[\"confusion_matrix\"]),\n        })\n        print(f\"  [A] Real-only \\u2192 \"\n              f\"F1={metrics_a['f1_macro']:.4f} | \"\n              f\"P={metrics_a['precision_macro']:.4f} | \"\n              f\"R={metrics_a['recall_macro']:.4f} | \"\n              f\"Acc={metrics_a['accuracy']:.4f}\")\n\n        if synthetic_df is not None and len(synthetic_df) > 0:\n            syn_sample = stratified_sample(\n                synthetic_df[[\"text\", \"binary_label\"]],\n                actual_n,\n                seed=seed,\n            )\n            augmented = pd.concat(\n                [real_sample[[\"text\", \"binary_label\"]], syn_sample],\n                ignore_index=True\n            )\n            print(f\"  Augmented: real={actual_n} + synthetic={len(syn_sample)} \"\n                  f\"= {len(augmented)} | {dict(augmented['binary_label'].value_counts())}\")\n\n            metrics_b = train_and_evaluate(augmented, test_df)\n            delta     = metrics_b[\"f1_macro\"] - metrics_a[\"f1_macro\"]\n\n            results.append({\n                \"scarcity_level\":           n,\n                \"condition\":                \"augmented\",\n                \"n_real\":                   actual_n,\n                \"n_synthetic\":              len(syn_sample),\n                \"n_total_train\":            len(augmented),\n                \"f1_macro\":                 metrics_b[\"f1_macro\"],\n                \"f1_substantive\":           metrics_b[\"f1_substantive\"],\n                \"f1_symbolic\":              metrics_b[\"f1_symbolic\"],\n                \"precision_macro\":          metrics_b[\"precision_macro\"],\n                \"recall_macro\":             metrics_b[\"recall_macro\"],\n                \"accuracy\":                 metrics_b[\"accuracy\"],\n                \"f1_improvement_over_real\": delta,\n                \"report\":                   metrics_b[\"report\"],\n                \"confusion_matrix\":         str(metrics_b[\"confusion_matrix\"]),\n            })\n            print(f\"  [B] Augmented \\u2192 \"\n                  f\"F1={metrics_b['f1_macro']:.4f} | \"\n                  f\"P={metrics_b['precision_macro']:.4f} | \"\n                  f\"R={metrics_b['recall_macro']:.4f} | \"\n                  f\"Acc={metrics_b['accuracy']:.4f} | \"\n                  f\"\\u0394F1={delta:+.4f}\")\n        else:\n            print(\"  [B] Augmented \\u2192 SKIPPED (no synthetic data available)\")\n\n    return results\n\n\nprint(f\"Running {len(SCARCITY_LEVELS) * 2} experimental conditions...\")\nresults = run_experiments(train_df, test_df, synthetic_df, SCARCITY_LEVELS, SEED)\nprint(\"\\nAll experiments complete.\")\n"
