   "source": "from IPython.display import FileLink\nimport anthropic\n\nSUBSTANTIVE_PROMPT = \"\"\"\\\nYou are an expert in ESG (Environmental, Social, and Governance) reporting.\nYour task is to generate one NEW substantive ESG claim.\n\nA SUBSTANTIVE claim describes a CONCRETE, IMPLEMENTED action or a SPECIFIC, \\\nMEASURABLE commitment. It includes verifiable details such as specific actions \\\ntaken, measurable targets, named programmes, or quantified outcomes.\n\nHere are two examples of SUBSTANTIVE claims from real corporate sustainability reports:\nExample 1: \"{ex1}\"\nExample 2: \"{ex2}\"\n\nGenerate exactly ONE new substantive ESG claim that:\n- Describes a concrete action already taken OR a specific, measurable commitment\n- Is realistic and consistent with corporate sustainability reporting language\n- Is different from the examples above\n- Is a single sentence between 15 and 50 words\n\nOutput ONLY the claim sentence, nothing else.\"\"\"\n\nSYMBOLIC_PROMPT = \"\"\"\\\nYou are an expert in ESG (Environmental, Social, and Governance) reporting.\nYour task is to generate one NEW symbolic ESG claim.\n\nA SYMBOLIC claim expresses a general intention, aspiration, or vague commitment \\\nWITHOUT specific verifiable details. It uses language like \"we aim to\", \\\n\"we are committed to\", \"we believe\", or similar non-committal phrasing.\n\nHere are two examples of SYMBOLIC claims from real corporate sustainability reports:\nExample 1: \"{ex1}\"\nExample 2: \"{ex2}\"\n\nGenerate exactly ONE new symbolic ESG claim that:\n- Expresses a general intention or aspiration without concrete verifiable details\n- Is realistic and consistent with corporate sustainability reporting language\n- Is different from the examples above\n- Is a single sentence between 15 and 50 words\n\nOutput ONLY the claim sentence, nothing else.\"\"\"\n\n\ndef deduplicate(new_texts, existing_texts, threshold=0.9):\n    clean = []\n    seen  = set(existing_texts)\n    for t in new_texts:\n        t_words = set(t.lower().split())\n        is_dup  = any(\n            len(t_words & set(e.lower().split())) /\n            max(len(t_words | set(e.lower().split())), 1) >= threshold\n            for e in seen\n        )\n        if not is_dup:\n            clean.append(t)\n            seen.add(t)\n    return clean\n\n\ndef generate_synthetic_data(train_df, n_per_label, api_key, seed=SEED):\n    client = anthropic.Anthropic(api_key=api_key)\n    existing_texts = set(train_df[\"text\"].tolist())\n    all_synthetic  = []\n\n    for label, prompt_template in [\n        (\"substantive\", SUBSTANTIVE_PROMPT),\n        (\"symbolic\",    SYMBOLIC_PROMPT),\n    ]:\n        print(f\"\\nGenerating {n_per_label} synthetic '{label}' examples...\")\n\n        pool     = train_df[train_df[\"binary_label\"] == label][\"text\"].tolist()\n        rng      = random.Random(seed)\n        examples = rng.sample(pool, min(4, len(pool)))\n\n        generated    = []\n        attempts     = 0\n        max_attempts = n_per_label * 3\n        fatal_error  = False\n\n        while len(generated) < n_per_label and attempts < max_attempts and not fatal_error:\n            ex1    = examples[attempts % len(examples)]\n            ex2    = examples[(attempts + 1) % len(examples)]\n            prompt = prompt_template.format(ex1=ex1, ex2=ex2)\n\n            try:\n                resp = client.messages.create(\n                    model=\"claude-sonnet-4-5\",\n                    max_tokens=200,\n                    messages=[{\"role\": \"user\", \"content\": prompt}],\n                )\n                text       = resp.content[0].text.strip()\n                word_count = len(text.split())\n                if 8 <= word_count <= 80:\n                    generated.append(text)\n\n            except Exception as e:\n                print(f\"  API error (attempt {attempts}): {e}\")\n                if \"404\" in str(e) or \"not_found\" in str(e) or \"401\" in str(e):\n                    print(\"  Fatal error — stopping.\")\n                    fatal_error = True\n                    break\n                time.sleep(2)\n\n            attempts += 1\n            if attempts % 20 == 0:\n                time.sleep(1)\n            if attempts % 50 == 0:\n                print(f\"  Progress: {len(generated)}/{n_per_label} ({attempts} attempts)\")\n\n        if fatal_error:\n            break\n\n        clean = deduplicate(generated, existing_texts)[:n_per_label]\n        print(f\"  \\u2192 {len(clean)} unique examples after deduplication\")\n\n        for text in clean:\n            all_synthetic.append({\n                \"text\":         text,\n                \"binary_label\": label,\n                \"synthetic\":    True,\n            })\n\n    syn_df    = pd.DataFrame(all_synthetic)\n    save_path = \"/kaggle/working/synthetic_data_master.json\"\n    syn_df.to_json(save_path, orient=\"records\", indent=2)\n    print(f\"\\nSynthetic data saved \\u2192 '{save_path}'\")\n    print(f\"Total: {len(syn_df)} examples | {dict(syn_df['binary_label'].value_counts())}\")\n    display(FileLink(save_path))\n\n    return syn_df\n\n\nsynthetic_df = None\n\nif GENERATE_SYNTHETIC:\n    if not ANTHROPIC_API_KEY:\n        print(\"ERROR: ANTHROPIC_API_KEY not set. Add it as a Kaggle Secret.\")\n    else:\n        print(f\"Generating synthetic data — target: {max(SCARCITY_LEVELS)} per label\")\n        synthetic_df = generate_synthetic_data(\n            train_df    = train_df,\n            n_per_label = max(SCARCITY_LEVELS),\n            api_key     = ANTHROPIC_API_KEY,\n            seed        = SEED,\n        )\nelse:\n    load_path = \"/kaggle/input/datasets/annieyang14/synthetic-data-generated/synthetic_data_master (1).json\"\n    if Path(load_path).exists():\n        synthetic_df = pd.read_json(load_path)\n        print(f\"Loaded synthetic data: {len(synthetic_df)} examples\")\n        print(dict(synthetic_df[\"binary_label\"].value_counts()))\n    else:\n        print(\"WARNING: synthetic_data_master.json not found.\")\n        print(\"Set GENERATE_SYNTHETIC = True and re-run this cell.\")\n"
