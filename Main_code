   "source": "aug_results  = [r for r in results if r[\"condition\"] == \"augmented\"]\nreal_results = [r for r in results if r[\"condition\"] == \"real_only\"]\n\nprint(\"\\n\" + \"=\" * 65)\nprint(\"RESEARCH QUESTION ANALYSIS\")\nprint(\"=\" * 65)\n\nprint(\"\\nRQ1: Effect of augmentation at each scarcity level\")\nprint(\"-\" * 55)\nfor r in aug_results:\n    delta = r[\"f1_improvement_over_real\"]\n    if   delta >  0.02:  direction = \"\\u2191 notable improvement\"\n    elif delta >  0.005: direction = \"\\u2191 marginal improvement\"\n    elif delta < -0.005: direction = \"\\u2193 performance degraded\"\n    else:                direction = \"\\u2192 negligible change\"\n    real_f1 = next(\n        x[\"f1_macro\"] for x in real_results\n        if x[\"scarcity_level\"] == r[\"scarcity_level\"]\n    )\n    print(f\"  n={r['scarcity_level']:>4}: real-only F1={real_f1:.4f} | \"\n          f\"augmented F1={r['f1_macro']:.4f} | \\u0394F1={delta:+.4f}  {direction}\")\n\nprint(\"\\nRQ2: Does benefit diminish as real data increases?\")\nprint(\"-\" * 55)\ndeltas = [r[\"f1_improvement_over_real\"] for r in aug_results]\nlevels = [r[\"scarcity_level\"]           for r in aug_results]\nfor lv, d in zip(levels, deltas):\n    bar = \"\\u2588\" * max(0, round(abs(d) * 200)) + (\"+\" if d >= 0 else \"-\")\n    print(f\"  n={lv:>4}: \\u0394F1={d:+.6f}  {bar}\")\n\nif len(deltas) >= 2:\n    trend_decreasing = deltas[-1] < deltas[0]\n    trend_label = (\n        \"Yes — benefit diminishes with more real data\"\n        if trend_decreasing else\n        \"No — benefit does not clearly diminish with more real data\"\n    )\n    print(f\"\\n  Trend: {trend_label}\")\n    max_delta = max(deltas)\n    max_level = levels[deltas.index(max_delta)]\n    print(f\"  Peak benefit at n={max_level} (\\u0394F1={max_delta:+.4f})\")\n"
