   "source": "def load_a3cg_json(path):\n    \"\"\"Load an A3CG JSON file and return a list of sentence records.\"\"\"\n    with open(path, \"r\", encoding=\"utf-8\") as f:\n        return json.load(f)\n\n\ndef flatten_to_aspects(records):\n    \"\"\"\n    Each aspect-claim instance is treated as a separate observation.\n    Converts sentence-level records into one row per (sentence, aspect) pair.\n    \"\"\"\n    rows = []\n    for rec in records:\n        text = rec[\"text\"].strip()\n        for aspect, labels in rec[\"aspects\"].items():\n            for orig_label in labels:\n                binary = LABEL_MAP.get(orig_label)\n                if binary is None:\n                    continue\n                rows.append({\n                    \"text\":           text,\n                    \"aspect\":         aspect,\n                    \"original_label\": orig_label,\n                    \"binary_label\":   binary,\n                })\n    return rows\n\n\ndef stratified_sample(df, n, seed):\n    \"\"\"\n    Stratified random sample without replacement, preserving the class ratio\n    of substantive and symbolic claims in each subset.\n    \"\"\"\n    if n >= len(df):\n        return df.copy()\n\n    label_counts  = df[\"binary_label\"].value_counts()\n    total         = len(df)\n    sampled_parts = []\n    allocated     = 0\n    labels        = list(label_counts.index)\n\n    for i, label in enumerate(labels):\n        k = (n - allocated) if i == len(labels) - 1 else round(n * label_counts[label] / total)\n        subset = df[df[\"binary_label\"] == label]\n        k = min(k, len(subset))\n        sampled_parts.append(subset.sample(n=k, random_state=seed, replace=False))\n        allocated += k\n\n    return pd.concat(sampled_parts).reset_index(drop=True)\n\n\nprint(\"Loading training data\")\ntrain_raw = load_a3cg_json(TRAIN_PATH)\ntrain_df  = pd.DataFrame(flatten_to_aspects(train_raw))\n\n# The test set remains fixed and contains only real, human-annotated data\nprint(\"Loading test data\")\ntest_raw = load_a3cg_json(TEST_PATH)\ntest_df  = pd.DataFrame(flatten_to_aspects(test_raw))\n\nprint(f\"\\n{'='*55}\")\nprint(f\"{'DATASET SUMMARY':^55}\")\nprint(f\"{'='*55}\")\nprint(f\"Training: {len(train_raw):>4} sentences \\u2192 {len(train_df):>5} aspect instances\")\nprint(f\"  substantive : {(train_df['binary_label']=='substantive').sum():>4}  \"\n      f\"({(train_df['binary_label']=='substantive').mean()*100:.1f}%)\")\nprint(f\"  symbolic    : {(train_df['binary_label']=='symbolic').sum():>4}  \"\n      f\"({(train_df['binary_label']=='symbolic').mean()*100:.1f}%)\")\nprint(f\"\\nTest:     {len(test_raw):>4} sentences \\u2192 {len(test_df):>5} aspect instances\")\nprint(f\"  substantive : {(test_df['binary_label']=='substantive').sum():>4}  \"\n      f\"({(test_df['binary_label']=='substantive').mean()*100:.1f}%)\")\nprint(f\"  symbolic    : {(test_df['binary_label']=='symbolic').sum():>4}  \"\n      f\"({(test_df['binary_label']=='symbolic').mean()*100:.1f}%)\")\nprint(f\"{'='*55}\")\n"
