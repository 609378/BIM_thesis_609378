   "source": "exclude    = {\"report\", \"confusion_matrix\"}\nresults_df = pd.DataFrame([\n    {k: v for k, v in r.items() if k not in exclude}\n    for r in results\n])\nresults_df.to_csv(RESULTS_PATH, index=False)\nprint(f\"Results saved \\u2192 '{RESULTS_PATH}'\\n\")\n\nprint(\"=\" * 88)\nprint(f\"{'RESULTS TABLE':^88}\")\nprint(f\"Primary metric: Macro F1  |  Fixed test set: {len(test_df)} aspect instances\")\nprint(\"=\" * 88)\nprint(f\"{'n (scarcity)':>12} {'Condition':>12} {'n_real':>7} {'n_syn':>6} \"\n      f\"{'F1 macro':>9} {'Precision':>10} {'Recall':>8} {'Accuracy':>9} {'\\u0394F1':>8}\")\nprint(\"-\" * 88)\nfor r in results:\n    delta_str = (f\"{r['f1_improvement_over_real']:+.4f}\"\n                 if r[\"condition\"] == \"augmented\" else \"  base\")\n    print(f\"{r['scarcity_level']:>12} {r['condition']:>12} \"\n          f\"{r['n_real']:>7} {r['n_synthetic']:>6} \"\n          f\"{r['f1_macro']:>9.4f} {r['precision_macro']:>10.4f} \"\n          f\"{r['recall_macro']:>8.4f} {r['accuracy']:>9.4f} \"\n          f\"{delta_str:>8}\")\nprint(\"=\" * 88)\n"
